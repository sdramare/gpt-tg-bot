aws_region      = "eu-north-1"
function_name   = "gpt-tg-bot"
lambda_role_name = "gpt-tg-bot-role"
lambda_zip_path = "../target/lambda/gpt-tg-bot/bootstrap.zip"
lambda_log_group_name = "/aws/lambda/gpt-tg-bot"

# Optional local rules file uploaded to private S3. Keep empty to disable.
gpt_rules_file_path = ""
# Optional S3 object key for uploaded rules.
# gpt_rules_object_key = "gpt-rules.txt"

# Uncomment when you build with arm64:
# lambda_architectures_override = ["arm64"]

lambda_environment = {
  BOT_ALIAS              = "@name_bot,Bot"
  DUMMY_ANSWERS          = "example1,example2"
  TG_TOKEN               = "replace-me"
  GPT_TOKEN              = "replace-me"
  GPT_MODEL              = "gpt-4.1"
  GPT_SMART_MODEL        = "gpt-5"
  GPT_RULES              = "replace-me"
  GPT_PREAMBLE           = "replace-me"
  TG_ALLOW_CHATS         = "123456789"
  NAMES_MAP              = "{\"Yury\":\"Yura\"}"

  # Optional keys currently used by live lambda:
  RUST_BACKTRACE         = "1"
  GPT_PRIVATE_TOKEN      = "replace-me"
  PRIVATE_GPT_RULES      = ""
  GPT_PRIVATE_MODEL      = "gpt-5-mini"
  GPT_IMAGE_MODEL        = "gpt-image-1"
  GPT_IMAGE_SIZE         = ""
  GPT_IMAGE_MODERATION   = ""
  GPT_CHAT_URL           = "https://api.openai.com/v1"
  GPT_PRIVATE_CHAT_URL   = "https://api.openai.com/v1"
}

lambda_tags = {}
